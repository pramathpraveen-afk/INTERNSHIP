<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forms</title>
</head>
<body>
    <h1>Enter Your Information</h1>
    
    <!-- form -->

    <form action="/submit" method="post">
       
        <!-- name -->

        <label for="name"><b>Name:</b></label>
        <input type="text" id="name" name="name" placeholder="Enter your name" required><br><br>
       
        <!-- age -->

        <label for="age"><b>Age:</b></label>
        <input type="number" id="age" name="age" placeholder="Enter your age" min="18" max="100" required><br><br>
       
        <!-- email -->

        <label for="email"><b>Email:</b></label>
        <input type="email" id="email" name="email" placeholder="Enter your email" required><br><br>
       
        <!-- password -->

        <label for="password"><b>Password:</b></label>
        <input type="password" id="password" name="password" placeholder="Enter your password" minlength="8" required><br><br>
       
        <!-- class -->

        <label for="Class"><b>Class:</b></label>
        <input type="text" id="Class" name="Class" placeholder="Enter your class" required><br><br>
       
        <!-- gender(radio) -->

        <label for="gender"><b>Gender:</b></label><br>
        <input type="radio" id="male" name="gender" value="male">
        <label for="male">Male</label><br>
        <input type="radio" id="female  " name="gender" value="female">
        <label for="female">Female</label><br>
        <input type="radio" id="other" name="gender" value="other">
        <label for="other">Other</label><br><br>
       
        <!-- country  -->

        <label for="country"><b>Country:</b></label>
        <select id="country" name="country" required>
            <option value="">Select your country</option>
            <option value="INDIA">INDIA</option>
            <option value="usa">United States</option>
            <option value="canada">Canada</option>
            <option value="uk">United Kingdom</option>
            <option value="australia">Australia</option>
        </select><br><br>
       
        <!-- textbox -->

        <label for="message"><b>Message:</b></label><br>
        <textarea id="message" name="message" rows="4" cols="30" placeholder="Enter your message here"></textarea><br><br>
        
        <!-- checkbox -->

        <input type="checkbox" id="subscribe" name="subscribe" value="yes">
        <label for="subscribe">Subscribe</label><br><br>

        <!-- fileupload -->

        <label for="fileUpload"><b>File Upload:</b></label><br>
        <input type="file" id="fileUpload" name="fileUpload"><br><br>

        <!-- datepicker -->

        <label for="dob"><b>Date of Birth:</b></label><br>
        <input type="date" id="datePicker" name="datePicker"><br><br>

        <!-- submit button -->

        <button>Submit</button>

        <!-- reset button -->

        <button type="reset">Reset</button>
    </form>
</body>
</html>